# =========================================================================
# CONFIGURACIÓN DEL ENTORNO DEL PROYECTO (GEN-02)
# =========================================================================

# Puerto local en el que correrá el servidor Express (ej: 3000)
PORT=3000

# Entorno de ejecución del sistema (development, production, test)
NODE_ENV=development

# -------------------------------------------------------------------------
# CONFIGURACIÓN DE LA BASE DE DATOS (MYSQL)
# -------------------------------------------------------------------------
# Dirección del servidor de la base de datos (ej: localhost o IP externa)
DB_HOST=localhost
# Puerto por defecto del motor MySQL (normalmente 3306)
DB_PORT=3306
# Nombre de la base de datos física creada para el sistema
DB_NAME=inscripcion_cursos
# Nombre de usuario administrador de la base de datos
DB_USER=root
# Contraseña de acceso del usuario de la base de datos
DB_PASSWORD=password

# URL completa de conexión (utilizada por Sequelize principalmente en producción)
DATABASE_URL=mysql://usuario:password@localhost:3306/inscripcion_cursos

# -------------------------------------------------------------------------
# SEGURIDAD Y CONECTIVIDAD
# -------------------------------------------------------------------------
# Clave secreta para la firma y validación de los tokens de sesión JWT
JWT_SECRET=tu_clave_secreta

# Origen permitido para las peticiones CORS desde el navegador del cliente
CORS_ORIGIN=http://localhost:5173

# URL base que el Frontend consume para conectarse a las rutas de la API
VITE_API_URL=http://localhost:3000/api